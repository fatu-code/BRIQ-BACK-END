# Postgres connection string (Supabase: Project Settings > Database > Connection string > URI)
DATABASE_URL=postgresql://user:password@host:5432/dbname

# Port (Railway sets this automatically in production)
PORT=4000

# Set to "false" only for a local Postgres without SSL. Supabase/Railway need SSL (leave unset).
# PGSSL=false

# Comma-separated list of allowed frontend origins for CORS (your Vercel URL)
CORS_ORIGIN=http://localhost:5500,http://127.0.0.1:5500
